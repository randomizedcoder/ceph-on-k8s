# Ignore build outputs from performing a nix-build or `nix build` command
result
result-*

# Ignore automatically generated direnv output
.direnv

# Ignore NixOS interactive test driver history
**/.nixos-test-history

# MicroVM data + Ceph disks (regenerated by `k8s-start-all`)
*.img
k8s-*-data.img
k8s-*-ceph.img

# QEMU monitor sockets
*.sock

# Cluster PKI dumped by `k8s-gen-certs` for inspection — contains
# private keys, never commit. Rebuilt from certs.nix at VM build time.
certs/

# Pre-generated application secrets. The SSH private key and pubkey
# in ./secrets/ must NOT land in git — secrets/ssh-ed25519 is a
# private key, secrets/ssh-ed25519.pub is harmless but excluded for
# symmetry. The Nix flake reads them via `builtins.pathExists` /
# `readFile` which works on untracked files (the source repo's
# `git add -N` dance is unnecessary here since secrets.nix has a
# fallback path when ./secrets/ is absent).
secrets/ssh-ed25519
secrets/ssh-ed25519.pub

# Chaos / failover test logs
chaos-logs/
chaos-logs-*/
