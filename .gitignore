# Ignore build outputs from performing a nix-build or `nix build` command
result
result-*

# Ignore automatically generated direnv output
.direnv

# Ignore NixOS interactive test driver history
**/.nixos-test-history

# MicroVM data + Ceph disks (regenerated by `k8s-start-all`)
*.img
k8s-*-data.img
k8s-*-ceph.img

# QEMU monitor sockets
*.sock

# Cluster PKI dumped by `k8s-gen-certs` for inspection — contains
# private keys, never commit. Rebuilt from certs.nix at VM build time.
certs/

# Pre-generated SSH material under ./secrets/.
#
# Deliberately NOT gitignored:
#   - secrets/ssh-ed25519.pub          — public, baked into VM authorized_keys
#   - secrets/host-keys/k8s-*.pub      — public, baked into host known_hosts
#   - secrets/known_hosts              — public, the host's known_hosts
#   - secrets/ssh-ed25519              — PRIVATE user key (do not commit!)
#   - secrets/host-keys/k8s-*          — PRIVATE per-node sshd host keys (do not commit!)
#
# Why all of them are tracked (with `git add --intent-to-add` from
# k8s-gen-secrets, not actually committed): a pure Nix flake can only
# read files Git knows about. If the privates were `.gitignore`d the
# flake couldn't bake host keys into VM images or the user pubkey
# into authorized_keys.
#
# The intent-to-add (`git add -N`) trick keeps the content on disk
# but with an empty blob in the index — so even `git commit -a`
# commits empty stubs, not the key material. Manual `git add
# secrets/`  followed by `git commit` would leak, so:
#   *** NEVER run `git add` on anything under secrets/ ***
# k8s-gen-secrets does the `git add --intent-to-add` itself.

# Chaos / failover test logs
chaos-logs/
chaos-logs-*/
